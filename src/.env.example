# ─────────────────────────────────────────────────────────────
# Fraud Detection System — Environment Variables Template
# Copy this file to .env and fill in the values before running.
# ─────────────────────────────────────────────────────────────

# ── Airflow ────────────────────────────────────────────────────
AIRFLOW_UID=50000
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=changeme

# ── PostgreSQL ─────────────────────────────────────────────────
POSTGRES_USER=airflow
POSTGRES_DB=airflow
POSTGRES_PASSWORD=changeme

# ── MinIO / S3 ─────────────────────────────────────────────────
MINIO_USERNAME=minioadmin
MINIO_PASSWORD=changeme
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=changeme

# ── Kafka ──────────────────────────────────────────────────────
# Internal Docker hostname for inter-container comms
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=transactions
KAFKA_FRAUD_TOPIC=fraud-alerts
# Leave blank for no auth (dev mode); set for Confluent Cloud / SASL_SSL
KAFKA_USERNAME=
KAFKA_PASSWORD=

# ── MLflow ─────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow-server:5500
MLFLOW_EXPERIMENT_NAME=fraud-detection

# ── Model Training ─────────────────────────────────────────────
TRAINING_N_SAMPLES=100000
MIN_F1_THRESHOLD=0.70
MODEL_PATH=/app/models/fraud_model.pkl

# ── Monitoring ─────────────────────────────────────────────────
MAX_CONSUMER_LAG=10000
EXPECTED_FRAUD_RATE_MIN=0.005
EXPECTED_FRAUD_RATE_MAX=0.05

# ── Notification / Email (optional) ───────────────────────────
# Leave blank to disable email alerts; structured logs are always emitted.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_FROM_EMAIL=fraud-alerts@example.com
ALERT_TO_EMAIL=
